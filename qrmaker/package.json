{
  "name": "qrmaker",
  "version": "0.3.3",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build:css": "tailwindcss -i src/styles.css -o popup.css --minify",
    "watch:css": "tailwindcss -i src/styles.css -o popup.css --watch",
    "lint": "eslint .",
    "test": "node --test",
    "vendor:qr": "cp node_modules/qr-code-styling/lib/qr-code-styling.js vendor/qr-code-styling.js",
    "vendor:jsqr": "cp node_modules/jsqr/dist/jsQR.js vendor/jsqr.js"
  },
  "dependencies": {
    "jsqr": "^1.4.0",
    "qr-code-styling": "^1.9.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@tailwindcss/cli": "^4.0.0",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "tailwindcss": "^4.0.0"
  }
}
